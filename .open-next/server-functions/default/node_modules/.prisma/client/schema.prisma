// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id        String   @id @default(cuid())
  nombre    String
  documento String   @unique // Int almacenado como String para cuid
  email     String   @unique
  password  String // bcrypt hash, cumple RN-001
  edad      Int // debe ser > 10, valida RN-002
  rol       Rol      @default(ATLETA)
  telefono  String?
  domicilio String?
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())

  // Relaciones
  planesComoAtleta     PlanEntrenamiento[]   @relation("AtletaPlan")
  planesComoEntrenador PlanEntrenamiento[]   @relation("EntrenadorPlan")
  sesiones             SesionEntrenamiento[]
}

enum Rol {
  ATLETA
  ENTRENADOR
  ADMIN
}

model PlanEntrenamiento {
  id              String   @id @default(cuid())
  objetivo        String
  duracionSemanas Int
  volumenSemanal  Float // km por semana
  activo          Boolean  @default(true) // RN-003: solo 1 activo
  atletaId        String
  entrenadorId    String
  createdAt       DateTime @default(now())

  atleta     Usuario               @relation("AtletaPlan", fields: [atletaId], references: [id])
  entrenador Usuario               @relation("EntrenadorPlan", fields: [entrenadorId], references: [id])
  sesiones   SesionEntrenamiento[]
  rutinas    RutinaEntrenamiento[]

  @@map("plan_entrenamiento")
}

enum EstadoRutina {
  PENDIENTE
  COMPLETADA
  REVISADA
  CANCELADA
}

model RutinaEntrenamiento {
  id                      String       @id @default(cuid())
  planId                  String
  nombre                  String
  descripcion             String
  tipoEntrenamiento       String
  fechaProgramada         DateTime
  distanciaObjetivo       Float
  tiempoObjetivo          Float
  intensidadEsperada      Int
  observacionesEntrenador String?
  estado                  EstadoRutina @default(PENDIENTE)
  resultadoPercibido      String?
  cumplimiento            Int?
  comentariosAtleta       String?
  molestiasFisicas        String?
  dificultadReal          Int?
  evidencia               String?
  feedbackEntrenador      String?
  recomendacionEntrenador String?
  decisionAjuste          String?
  completadaAt            DateTime?
  revisadaAt              DateTime?
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt

  plan   PlanEntrenamiento    @relation(fields: [planId], references: [id])
  sesion SesionEntrenamiento?

  @@map("rutina_entrenamiento")
}

model SesionEntrenamiento {
  id            String   @id @default(cuid())
  atletaId      String
  planId        String
  rutinaId      String?  @unique
  distancia     Float // km
  tiempo        Float // minutos
  nivelEsfuerzo Int // 1-10
  fecha         DateTime
  createdAt     DateTime @default(now())

  atleta Usuario              @relation(fields: [atletaId], references: [id])
  plan   PlanEntrenamiento    @relation(fields: [planId], references: [id])
  rutina RutinaEntrenamiento? @relation(fields: [rutinaId], references: [id])

  @@map("sesion_entrenamiento")
}
