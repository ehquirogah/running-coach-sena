  "dynamicRoutes": [
    {
      "page": "/api/auth/[...nextauth]",
      "regex": "^/api/auth/(.+?)(?:/)?$",
      "routeKeys": {
        "nxtPnextauth": "nxtPnextauth"
      },
      "namedRegex": "^/api/auth/(?<nxtPnextauth>.+?)(?:/)?$"
    },
    {
      "page": "/api/reportes/[atletaId]",
      "regex": "^/api/reportes/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPatletaId": "nxtPatletaId"
      },
      "namedRegex": "^/api/reportes/(?<nxtPatletaId>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/sesiones/atleta/[id]",
